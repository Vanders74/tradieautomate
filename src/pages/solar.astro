---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = "Solar & Battery Installer Resources | TradieAutomate";
const description = "Resources, tools, and guides for Australian solar and battery installers. Check the health of your online review profile and discover how to win more work.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main>

      <!-- Hero Section -->
      <section class="solar-hero">
        <h1>Resources for Australian Solar &amp; Battery Installers</h1>
        <p class="hero-sub">
          Practical tools and guides to help you stay compliant, win more reviews,
          and grow your solar business.
        </p>
      </section>

      <!-- VSL / Video Section -->
      <section class="vsl-section">
        <div class="vsl-wrapper">
          <div class="vsl-placeholder">
            <span class="vsl-icon">▶</span>
            <p>Watch: How Top Solar Installers Automate Their Business</p>
          </div>
        </div>
      </section>

      <!-- Quiz Section (below VSL, above CTA) -->
      <section class="quiz-section">
        <div class="quiz-intro">
          <h2>How Healthy Is Your Review Profile?</h2>
          <p>
            Your online reviews are one of the biggest factors in winning new solar jobs.
            Take this 2-minute quiz to find out how your review profile stacks up — and
            what to do if it's holding you back.
          </p>
        </div>
        <div class="quiz-embed">
          <iframe src="https://review-health-quiz-6906bc3c.viktor.space" width="100%" height="750" frameborder="0" style="border-radius:12px;" title="Review Health Quiz"></iframe>
        </div>
      </section>

      <!-- CTA Section -->
      <div class="cta-box">
        <h3>Want more guides like this?</h3>
        <p>
          TradieAutomate covers compliance, job management, and trade business growth
          for Australian solar, battery and electrical installers. No fluff — just
          practical information.
        </p>
        <a href="/blog" class="cta-button">Read the Blog →</a>
      </div>

    </main>
    <Footer />
  </body>
</html>

<style>
  /* Hero */
  .solar-hero {
    text-align: center;
    padding: 2.5em 1em 2em;
    margin-bottom: 1em;
  }
  .solar-hero h1 {
    font-size: 2.2em;
    line-height: 1.2;
    color: var(--navy, #1B2B4B);
    margin-bottom: 0.5em;
  }
  .hero-sub {
    font-size: 1.05em;
    color: rgb(var(--gray-dark));
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* VSL */
  .vsl-section {
    margin-bottom: 3em;
  }
  .vsl-wrapper {
    border-radius: 14px;
    overflow: hidden;
    background: var(--navy, #1B2B4B);
    aspect-ratio: 16 / 9;
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .vsl-placeholder {
    text-align: center;
    color: rgba(255,255,255,0.7);
  }
  .vsl-icon {
    font-size: 3em;
    display: block;
    margin-bottom: 0.4em;
    color: var(--accent);
  }
  .vsl-placeholder p {
    font-size: 0.95em;
    margin: 0;
  }

  /* Quiz Section */
  .quiz-section {
    margin-bottom: 3em;
  }
  .quiz-intro {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 1.75em;
  }
  .quiz-intro h2 {
    font-size: 1.8em;
    color: var(--navy, #1B2B4B);
    margin-bottom: 0.5em;
  }
  .quiz-intro p {
    font-size: 1em;
    color: rgb(var(--gray-dark));
    line-height: 1.65;
    margin: 0;
  }
  .quiz-embed {
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.10);
  }

  /* CTA */
  .cta-box {
    background: var(--navy, #1B2B4B);
    color: white;
    border-radius: 14px;
    padding: 2em;
    margin-top: 1em;
    text-align: center;
  }
  .cta-box h3 {
    color: white;
    font-size: 1.4em;
    margin-bottom: 0.5em;
  }
  .cta-box p {
    color: rgba(255,255,255,0.82);
    font-size: 0.95em;
    max-width: 500px;
    margin: 0 auto 1.25em;
  }
  .cta-button {
    display: inline-block;
    background: var(--accent);
    color: white;
    font-weight: 700;
    padding: 0.7em 1.8em;
    border-radius: 8px;
    text-decoration: none;
    font-size: 1em;
    transition: background 0.2s;
  }
  .cta-button:hover {
    background: var(--accent-dark);
    color: white;
  }

  @media (max-width: 720px) {
    .solar-hero h1 { font-size: 1.7em; }
    .quiz-intro h2 { font-size: 1.4em; }
    .cta-box { padding: 1.5em 1.25em; }
  }
</style>
